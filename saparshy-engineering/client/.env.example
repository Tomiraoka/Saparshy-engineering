VITE_API_URL=http://localhost:5000/api

# EmailJS — уведомление на почту компании о новой заявке (необязательно).
# Если оставить пустыми, заявка всё равно сохранится в БД, просто без письма.
# Нужно создать в личном кабинете EmailJS новый шаблон с переменными:
# from_name, from_phone, from_email, service, message
VITE_EMAILJS_SERVICE_ID=
VITE_EMAILJS_TEMPLATE_ID=
VITE_EMAILJS_PUBLIC_KEY=
VITE_COMPANY_EMAIL=info@saparshy-engineering.kz
